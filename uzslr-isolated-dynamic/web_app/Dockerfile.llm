# Web app + Ollama + alloma-3b-q4 model bundled inside the image.
#
# BUILD (from repo root):
#   # copy model cache first (one-time):
#   mkdir -p web_app/ollama-models
#   cp -r ~/.ollama/models/blobs     web_app/ollama-models/blobs
#   cp -r ~/.ollama/models/manifests web_app/ollama-models/manifests
#
#   docker build --platform=linux/amd64 -f web_app/Dockerfile.llm -t uzslr-web:llm .
#
# RUN — CPU only (any machine):
#   docker run -p 7860:7860 uzslr-web:llm
#
# RUN — GPU (requires NVIDIA Container Toolkit on the host):
#   docker run --gpus all -p 7860:7860 uzslr-web:llm
#
# Ollama and PyTorch both auto-detect CUDA at runtime.
# No rebuild needed — same image works on CPU and GPU.

FROM python:3.9-slim

# system deps 
RUN apt-get update && apt-get install -y --no-install-recommends \
        libglib2.0-0 \
        libgl1 \
        libgomp1 \
        libgcc-s1 \
        curl \
        zstd \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Ollama binary 
# The install script detects NVIDIA drivers at RUNTIME (not build time),
# so the same binary serves both CPU and GPU deployments.
RUN curl -fsSL https://ollama.com/install.sh | sh

# working directory 
WORKDIR /app

# python deps 
COPY web_app/requirements-docker.txt /app/requirements.txt
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# application source 
COPY web_app/backend/          /app/web_app/backend/
COPY web_app/__init__.py       /app/web_app/__init__.py
RUN  touch                     /app/web_app/backend/__init__.py
COPY web_app/frontend/         /app/web_app/frontend/
COPY web_app/best_model.pth    /app/web_app/best_model.pth

# pre-rendered sign videos
COPY web_app/sign_videos/       /app/web_app/sign_videos/
COPY show-50-signs/signs/      /app/show-50-signs/signs/

# Ollama model weights 
COPY web_app/ollama-models/blobs/      /root/.ollama/models/blobs/
COPY web_app/ollama-models/manifests/  /root/.ollama/models/manifests/

# environment 
ENV LLM_ENABLED=true
ENV OLLAMA_BIN=/usr/local/bin/ollama
ENV OLLAMA_MODELS=/root/.ollama/models

# Ollama GPU memory control — leave headroom for PyTorch sign model.
# On a GPU with 8GB+ VRAM this is safe. Adjust if you have less.
# Set to 0 to let Ollama use all available VRAM.
# ENV OLLAMA_GPU_OVERHEAD=512000000

# runtime 
EXPOSE 7860
CMD ["uvicorn", "web_app.backend.main:app", "--host", "0.0.0.0", "--port", "7860"]